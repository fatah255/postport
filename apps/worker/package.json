{
  "name": "@postport/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test test/**/*.test.js",
    "format": "echo \"format worker\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.701.0",
    "@aws-sdk/s3-request-presigner": "^3.701.0",
    "@postport/config": "workspace:*",
    "@postport/platform-sdk": "workspace:*",
    "@postport/utils": "workspace:*",
    "@prisma/client": "^5.21.1",
    "bullmq": "^5.14.1",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@postport/eslint-config": "workspace:*",
    "@postport/tsconfig": "workspace:*",
    "@types/node": "^22.8.0",
    "eslint": "^9.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
