{
  "name": "@postport/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsc -p tsconfig.build.json && node dist/src/main.js",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "pnpm exec eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "format": "echo \"format api\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.701.0",
    "@aws-sdk/s3-request-presigner": "^3.701.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/swagger": "^11.0.1",
    "@nestjs/throttler": "^6.2.0",
    "@postport/config": "workspace:*",
    "@postport/platform-sdk": "workspace:*",
    "@postport/utils": "workspace:*",
    "@prisma/client": "^5.21.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.14.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@postport/eslint-config": "workspace:*",
    "@postport/tsconfig": "workspace:*",
    "@types/node": "^22.8.0",
    "eslint": "^9.12.0",
    "prisma": "^5.21.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
