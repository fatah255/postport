{
  "extends": "@postport/tsconfig/nest.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "strictPropertyInitialization": false
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts"
  ]
}
