NODE_ENV=development
LOG_LEVEL=info

API_PORT=3001
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

JWT_ACCESS_SECRET=replace_with_32_plus_chars_access_secret
JWT_REFRESH_SECRET=replace_with_32_plus_chars_refresh_secret
SESSION_COOKIE_NAME=postport_session
TOKEN_ENCRYPTION_KEY=replace_with_16_plus_chars_token_key

RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120
SIGNED_UPLOAD_EXPIRY_SECONDS=900

# Local Docker defaults
DATABASE_URL=postgresql://postport:postport@localhost:5432/postport?schema=public
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=postport-media
S3_FORCE_PATH_STYLE=true
SIGNED_MEDIA_URL_EXPIRY_SECONDS=3600
MEDIA_PROCESSING_TEMP_DIR=.tmp/media-processing

ALLOW_MOCK_CONNECTIONS=false
META_APP_ID=1633823354336156
META_APP_SECRET=
META_LOGIN_CONFIG_ID=
META_REDIRECT_URI=http://localhost:3001/connections/{platform}/callback
META_API_VERSION=v23.0
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3001/connections/tiktok/callback

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_LOCALE=en
